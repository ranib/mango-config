[
    {
        "label": "lock",
        "action": "bash ~/.config/mango/scripts/wallpaper_lockscreen.sh",
        "text": "Lock",
        "keybind": "l"
    },
    {
        "label": "hibernate",
        "action": "systemctl hibernate",
        "text": "Hibernate",
        "keybind": "h"
    },
    {
        "label": "logout",
        "action": "mango-msg exit",
        "text": "Exit",
        "keybind": "e"
    },
    {
        "label": "shutdown",
        "action": "systemctl poweroff",
        "text": "Shutdown",
        "keybind": "s"
    },
    {
        "label": "suspend",
        "action": "systemctl suspend",
        "text": "Suspend",
        "keybind": "u"
    },
    {
        "label": "reboot",
        "action": "systemctl reboot",
        "text": "Reboot",
        "keybind": "r"
    }
}
